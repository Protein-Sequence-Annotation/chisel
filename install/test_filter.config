# test_filter.config — generated by make config (do not commit)
# Run: make config   (writes install/test_filter.config)
#
# DB_FILE and FIXED_FILE are passed on the command line (--db-file, --fixed-file).
# test_installation.sh rewrites OUT_DIR and tool paths via write_filter_config_to().

OUT_DIR="check"
KEEP_INTERMEDIATES="1"
TASK_ID="0"
REMOVE_TARGET="db"
USE_LONG_ID="1"
CHISEL_PROFILE="filter"

E_VALUE="0.01"
Z_SIZE="100"

PHMMER_CORES="1"
MMSEQS_CORES="1"
BLAST_CORES="1"
SW_CORES="1"
SW_SHARDS="1"

PHMMER_FILTER="/n/eddy_lab/Lab/protein_annotation_dl/chisel/bin/phmmer_filter"
MMSEQS="/n/eddy_lab/Lab/protein_annotation_dl/chisel/external_tools/mmseqs/bin/mmseqs"
BLAST_DIR="/n/eddy_lab/Lab/protein_annotation_dl/chisel/external_tools/ncbi-blast/bin"
FASTA_DIR="/n/eddy_lab/Lab/protein_annotation_dl/chisel/external_tools/fasta36/bin"

BLAST_DBSIZE="3000"
BLAST_MAX_TARGET_SEQS="100"
MMSEQS_MAX_SEQS="100"

FILTER_PHMMER_PHIGH="0"
FILTER_PHMMER_PLOW="0"
FILTER_PHMMER_QSIZE="100"
FILTER_PHMMER_EXTRA=""
FILTER_MMSEQS_SEARCH_EXTRA="--alignment-mode 2 --cov-mode 0 -c 0"
FILTER_MMSEQS_CONVERTALIS_EXTRA="--format-mode 2"
FILTER_BLASTP_EXTRA=""
FILTER_SW_EXTRA=""
