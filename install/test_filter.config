# test_filter.config — minimal config for install/test_installation.sh (fast CI-sized runs).
# For production pipelines, copy and edit install/chisel.config instead.
#
# DB_FILE and FIXED_FILE are passed on the command line (--db-file, --fixed-file).
# test_installation.sh rewrites OUT_DIR and tool paths via write_filter_config_to().

OUT_DIR="check"
KEEP_INTERMEDIATES="1"
TASK_ID="0"
REMOVE_TARGET="db"
USE_LONG_ID="1"

E_VALUE="0.01"
Z_SIZE="100"

PHMMER_CORES="1"
MMSEQS_CORES="1"
BLAST_CORES="1"
SW_CORES="1"

PHMMER_FILTER="bin/phmmer_filter"
MMSEQS="external_tools/mmseqs/bin/mmseqs"
BLAST_DIR="external_tools/ncbi-blast/bin"
FASTA_DIR="external_tools/fasta36/bin"

SW_LEGACY="0"
SW_SHARDS="1"

BLAST_DBSIZE="3000"
BLAST_MAX_TARGET_SEQS="100"
MMSEQS_MAX_SEQS="100"
