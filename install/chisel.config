# chisel.config — unified configuration for chisel_build, chisel_filter, and chisel_dedup.
#
# Copy this file, set CHISEL_ROOT if needed, and pass it to any Chisel pipeline script:
#   chisel_build  --config chisel.config --input-db DB.fasta --output-dir out/
#   chisel_dedup  --config chisel.config --test-file test.fasta --val-file val.fasta --output-dir out/
#   chisel_filter --config chisel.config --order mbps --fixed-file A.fasta --db-file B.fasta
#
# Each tool validates only the variables it uses; other sections are ignored.
# Paths below are relative to CHISEL_ROOT unless absolute.

CHISEL_ROOT="."

# --- Common ---
TASK_ID="0"
KEEP_INTERMEDIATES=""

# --- chisel_build: filter tool order (chisel_build reads this; chisel_filter uses --order on CLI) ---
ORDER="mbps"

# --- chisel_build: splitter (chisel_splitter) ---
SPLIT_CPU="96"
SPLIT_DBBLOCK="10000"
SPLIT_INIT_CHUNK="100"
SPLIT_TEST_LIMIT="500"
SPLIT_VAL_LIMIT="100"
SPLIT_SEED="42"
SPLIT_SUPPRESS="0"
# SPLIT_Z defaults to Z_SIZE when unset

# --- chisel_filter / chisel_build: E-value and database size ---
E_VALUE="0.01"
Z_SIZE="81514348"

# --- Cores per tool ---
PHMMER_CORES="96"
MMSEQS_CORES="96"
BLAST_CORES="96"
SW_CORES="96"

# --- Tool binaries / directories ---
PHMMER_FILTER="bin/phmmer_filter"
MMSEQS="external_tools/mmseqs/bin/mmseqs"
BLAST_DIR="external_tools/ncbi-blast/bin"
FASTA_DIR="external_tools/fasta36/bin"

# --- Smith–Waterman: 0 = Sledge fasta36; 1 = legacy upstream ---
SW_LEGACY="0"
SW_SHARDS="4"

# --- Long ID parsing (MMseqs): 1 = use 2nd pipe field in FASTA headers ---
USE_LONG_ID="1"

# --- BLAST / MMseqs limits ---
BLAST_DBSIZE="32596740121"
BLAST_MAX_TARGET_SEQS="10000000"
MMSEQS_MAX_SEQS="10000000"

# --- chisel_filter: output directory and removal side (db|fixed) ---
# chisel_build overrides OUT_DIR per step and forces REMOVE_TARGET=fixed for pruning.
OUT_DIR="."
REMOVE_TARGET="fixed"

# --- chisel_dedup: phmmer_filter self-deduplication ---
DEDUP_PHIGH="0.5"
DEDUP_PLOW="0"
DEDUP_QSIZE="100"
# DEDUP_SUPPRESS="1"  # optional: silence phmmer progress (default 0)
