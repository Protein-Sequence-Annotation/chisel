# test_filter.config.in — minimal config for make test-install (fast CI-sized runs).
# Run: make config   (writes install/test_filter.config)
#
# DB_FILE and FIXED_FILE are passed on the command line (--db-file, --fixed-file).
# test_installation.sh rewrites OUT_DIR and tool paths via write_filter_config_to().

OUT_DIR="check"
KEEP_INTERMEDIATES="1"
TASK_ID="0"
REMOVE_TARGET="db"
USE_LONG_ID="1"
CHISEL_PROFILE="filter"

E_VALUE="0.01"
Z_SIZE="100"

PHMMER_CORES="1"
MMSEQS_CORES="1"
BLAST_CORES="1"
SW_CORES="1"

PHMMER_FILTER="@CHISEL_ROOT@/bin/phmmer_filter"
MMSEQS="@CHISEL_ROOT@/external_tools/mmseqs/bin/mmseqs"
BLAST_DIR="@CHISEL_ROOT@/external_tools/ncbi-blast/bin"
FASTA_DIR="@CHISEL_ROOT@/external_tools/fasta36/bin"

SW_LEGACY="0"
SW_SHARDS="1"

BLAST_DBSIZE="3000"
BLAST_MAX_TARGET_SEQS="100"
MMSEQS_MAX_SEQS="100"

FILTER_PHMMER_PHIGH="0"
FILTER_PHMMER_PLOW="0"
FILTER_PHMMER_QSIZE="100"
FILTER_PHMMER_EXTRA=""
FILTER_MMSEQS_SEARCH_EXTRA="--alignment-mode 2 --cov-mode 0 -c 0"
FILTER_MMSEQS_CONVERTALIS_EXTRA="--format-mode 2"
FILTER_BLASTP_EXTRA=""
FILTER_SW_EXTRA="-s BL62 -z 3 -f -11 -g -1"
FILTER_SW_PASS1_X="early_stop"
FILTER_SW_PASS2_X="all_hits"
