# chisel.config.in — default Chisel pipeline settings (template).
# Run: make config   (writes install/chisel.config with absolute paths)
#
# Usage:
#   chisel_build  --config install/chisel.config --input-db DB.fasta --output-dir out/
#   chisel_dedup  --config install/chisel.config --file test.fasta [--output-dir out/]
#   chisel_filter --config install/chisel.config --order mbps --fixed-file A.fasta --db-file B.fasta
#
# Edit this .in file to change shipped defaults, then run make config.
# After generation, you may edit install/chisel.config directly (it is gitignored).

CHISEL_ROOT="@CHISEL_ROOT@"

# --- Common ---
TASK_ID="0"
KEEP_INTERMEDIATES="0"

# --- chisel_build: filter tool order (chisel_filter uses --order on CLI) ---
ORDER="mbps"

# --- chisel_build: splitter (chisel_splitter) ---
SPLIT_CPU="96"
SPLIT_DBBLOCK="10000"
SPLIT_INIT_CHUNK="50"
SPLIT_TEST_LIMIT="500"
SPLIT_VAL_LIMIT="100"
# SPLIT_SEED: 0 = random train/test/val assignment; >0 = reproducible splits
SPLIT_SEED="0"
SPLIT_SUPPRESS="0"
# SPLIT_Z defaults to Z_SIZE when unset
SPLITTER_EXTRA=""

# --- chisel_filter / chisel_build: E-value and database size ---
E_VALUE="0.01"
Z_SIZE="81514348"

# --- Cores per tool ---
PHMMER_CORES="96"
MMSEQS_CORES="96"
BLAST_CORES="96"
SW_CORES="96"
# Parallel ssearch36 processes (query shards); threads per shard = SW_CORES / SW_SHARDS
SW_SHARDS="8"

# --- Tool binaries / directories (filled by make config) ---
PHMMER_FILTER="@CHISEL_ROOT@/bin/phmmer_filter"
MMSEQS="@CHISEL_ROOT@/external_tools/mmseqs/bin/mmseqs"
BLAST_DIR="@CHISEL_ROOT@/external_tools/ncbi-blast/bin"
FASTA_DIR="@CHISEL_ROOT@/external_tools/fasta36/bin"

# --- Long ID parsing (MMseqs): 1 = use 2nd pipe field in FASTA headers ---
USE_LONG_ID="1"

# --- BLAST / MMseqs limits ---
BLAST_DBSIZE="32596740121"
BLAST_MAX_TARGET_SEQS="10000000"
MMSEQS_MAX_SEQS="10000000"

# --- chisel_filter: output directory and removal side (db|fixed) ---
OUT_DIR="."
REMOVE_TARGET="db"

# --- chisel_build filter steps (chisel_filter with CHISEL_PROFILE=build) ---
# --- PHMMER FILTER ARGS ---
BUILD_FILTER_PHMMER_PHIGH="0"
BUILD_FILTER_PHMMER_PLOW="0"
BUILD_FILTER_PHMMER_QSIZE="100"
BUILD_FILTER_PHMMER_EXTRA=""

# --- MMSEQS FILTER ARGS ---
BUILD_FILTER_MMSEQS_SEARCH_EXTRA="--alignment-mode 2 --cov-mode 0 -c 0"
BUILD_FILTER_MMSEQS_CONVERTALIS_EXTRA="--format-mode 2"

# --- BLAST FILTER ARGS ---
BUILD_FILTER_BLASTP_EXTRA=""

# --- SSEARCH36 FILTER ARGS ---
BUILD_FILTER_SW_EXTRA=""

# --- chisel_filter (standalone; CHISEL_PROFILE=filter) ---
# --- PHMMER FILTER ARGS ---
FILTER_PHMMER_PHIGH="0"
FILTER_PHMMER_PLOW="0"
FILTER_PHMMER_QSIZE="100"
FILTER_PHMMER_EXTRA=""

# --- MMSEQS FILTER ARGS ---
FILTER_MMSEQS_SEARCH_EXTRA="--alignment-mode 2 --cov-mode 0 -c 0"
FILTER_MMSEQS_CONVERTALIS_EXTRA="--format-mode 2"

# --- BLAST FILTER ARGS ---
FILTER_BLASTP_EXTRA=""

# --- SSEARCH36 FILTER ARGS ---
FILTER_SW_EXTRA=""

# --- chisel_dedup: phmmer_filter self-deduplication ---
DEDUP_PHIGH="0.5"
DEDUP_PLOW="0"
DEDUP_QSIZE="100"
DEDUP_EXTRA=""
DEDUP_SUPPRESS="0"
